  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cap:prepare": "node -e \"const fs=require('fs');fs.mkdirSync('out',{recursive:true});fs.copyFileSync('capacitor-web/error.html','out/error.html');fs.copyFileSync('capacitor-web/index.html','out/index.html')\"",
    "cap:sync": "npm run cap:prepare && npx cap sync ios",
    "cap:open": "npx cap open ios",
